# DataSmart Govern 全平台 Compose 本地环境样例。
#
# 使用前可复制为仓库根目录 `.env.application`，再通过
# `docker compose --env-file .env.application -f docker-compose.yml -f docker-compose.application.yml ...`
# 注入。这里的默认值仅用于本地学习与 E2E，生产环境必须由 Secret Manager、CI/CD Secret 或集群 Secret 提供。

DATASMART_IMAGE_TAG=local
DATASMART_RUNTIME_PROFILE=container
# 本地开发、演示和 E2E 默认使用北京时间。生产环境如统一采用 UTC，可在部署环境覆盖该值。
DATASMART_TIME_ZONE=Asia/Shanghai

# 基础设施本地凭据。生产环境不得沿用示例值。
# PostgreSQL 是目标数据库；MySQL 仅在渐进迁移期间保留。
DATASMART_POSTGRES_PASSWORD=password
DATASMART_LOCAL_POSTGRES_PORT=5432
DATASMART_MYSQL_PASSWORD=password
DATASMART_LOCAL_MYSQL_PORT=13306
DATASMART_NEO4J_PASSWORD=password
DATASMART_MINIO_ACCESS_KEY=datasmart
DATASMART_MINIO_SECRET_KEY=datasmart123
DATASMART_GRAFANA_ADMIN_PASSWORD=admin

# Gateway 与 Python Runtime 之间的 HMAC 密钥。至少使用 32 字节高熵随机值。
DATASMART_GATEWAY_SIGNATURE_SECRET=replace-with-a-long-random-secret
DATASMART_GATEWAY_SIGNATURE_KEY_ID=gateway-compose-v1

# datasource-management 外部数据源密码字段级加密主密钥。
# 本地可使用长随机字符串；生产必须由 Secret Manager/Kubernetes Secret/Docker secret 注入，不能提交真实值。
DATASMART_DATASOURCE_CREDENTIAL_MASTER_KEY=replace-with-a-long-random-datasource-credential-key
DATASMART_DATASOURCE_CREDENTIAL_KEY_ID=compose-local-v1

# Token 的 issuer 仍使用宿主机可访问地址；gateway 容器通过内部 JWK URL 获取公钥。
DATASMART_GATEWAY_OIDC_ISSUER_URI=http://localhost:18080/realms/datasmart
DATASMART_KEYCLOAK_ADMIN_USERNAME=admin
DATASMART_KEYCLOAK_ADMIN_PASSWORD=admin
DATASMART_KEYCLOAK_DB_NAME=keycloak
DATASMART_KEYCLOAK_DB_USERNAME=keycloak
DATASMART_KEYCLOAK_DB_PASSWORD=keycloak
DATASMART_KEYCLOAK_ADMIN_REALM=master
DATASMART_KEYCLOAK_TARGET_REALM=datasmart
DATASMART_KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
DATASMART_KEYCLOAK_ADMIN_CLIENT_SECRET=
DATASMART_KEYCLOAK_ASSIGN_REALM_ROLE=true
DATASMART_KEYCLOAK_REALM_ROLE_PREFIX=DATASMART_

# 可选真实模型服务。留空 BASE_URL 时 Python Runtime 仍可提供规则式降级、LangGraph 和低敏诊断能力。
# BASE_URL 支持 https://host、https://host/v1，或与 WIRE_API 对应的完整 endpoint。
# API_KEY 只填入本地 .env.application 或 Secret Manager，禁止提交到 Git、前端或日志。
# MODEL 是中转站 /v1/models 或文档返回的真实 model ID，例如站点定义的 gpt5.6。
DATASMART_AI_OPENAI_COMPATIBLE_BASE_URL=
DATASMART_AI_OPENAI_COMPATIBLE_API_KEY=
DATASMART_AI_OPENAI_COMPATIBLE_USER_AGENT=DataSmart-AI-Runtime/1.0
# chat_completions 兼容面更广；responses 支持标准 function_call/function_call_output 与推理强度。
DATASMART_AI_OPENAI_COMPATIBLE_WIRE_API=chat_completions
# Responses API 推理强度可选 none/minimal/low/medium/high/xhigh；普通聊天模型可留空。
DATASMART_AI_AGENT_REASONING_EFFORT=
# 默认 false，避免第三方 Provider 持久化响应；生产数据处理协议仍需单独审查 Provider 日志策略。
DATASMART_AI_OPENAI_COMPATIBLE_STORE_RESPONSE=false
# 标准 Provider 使用 native；只有确认中转站不透传 tool_calls 且支持 json_object 时才使用 json_fallback。
DATASMART_AI_OPENAI_COMPATIBLE_TOOL_CALL_MODE=native
DATASMART_AI_AGENT_REASONING_MODEL=
DATASMART_AI_AGENT_REASONING_PROVIDER_NAME=openai-compatible-agent-router
DATASMART_AI_AGENT_REASONING_TIMEOUT_SECONDS=90
DATASMART_AI_AGENT_REASONING_MAX_CONTEXT_TOKENS=131072
DATASMART_AI_OPENAI_COMPATIBLE_MAX_RETRIES=1
DATASMART_AI_OPENAI_COMPATIBLE_RETRY_BACKOFF_SECONDS=0.5

# Durable Agent Loop checkpoint。Compose 已默认使用 Redis DB 2，保留 24 小时；
# 如果客户环境需要更长人工审批窗口，应结合 Redis 容量和审计留存策略调整 TTL。
DATASMART_AGENT_DURABLE_LOOP_STORE=redis
DATASMART_AGENT_DURABLE_LOOP_REDIS_URL=redis://redis:6379/2
DATASMART_AGENT_DURABLE_LOOP_TTL_SECONDS=86400

# 所有镜像默认通过 DaoCloud；若客户环境使用 Harbor/Nexus，可逐项覆盖为私有仓库地址。
DATASMART_POSTGRES_IMAGE=docker.m.daocloud.io/pgvector/pgvector:0.8.3-pg17
DATASMART_MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.0
DATASMART_REDIS_IMAGE=docker.m.daocloud.io/library/redis:7.2-alpine
DATASMART_ZOOKEEPER_IMAGE=docker.m.daocloud.io/confluentinc/cp-zookeeper:7.6.0
DATASMART_KAFKA_IMAGE=docker.m.daocloud.io/confluentinc/cp-kafka:7.6.0
DATASMART_NEO4J_IMAGE=docker.m.daocloud.io/library/neo4j:5.20
DATASMART_MINIO_IMAGE=docker.m.daocloud.io/minio/minio:latest
DATASMART_NACOS_IMAGE=docker.m.daocloud.io/nacos/nacos-server:v2.3.0
DATASMART_KEYCLOAK_IMAGE=quay.m.daocloud.io/keycloak/keycloak:26.6.4
DATASMART_PROMETHEUS_IMAGE=docker.m.daocloud.io/prom/prometheus:latest
DATASMART_ALERTMANAGER_IMAGE=docker.m.daocloud.io/prom/alertmanager:latest
DATASMART_GRAFANA_IMAGE=docker.m.daocloud.io/grafana/grafana:latest
DATASMART_CHROMA_IMAGE=docker.m.daocloud.io/chromadb/chroma:latest
