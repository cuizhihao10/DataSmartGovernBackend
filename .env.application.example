# DataSmart Govern 全平台 Compose 本地环境样例。
#
# 使用前可复制为仓库根目录 `.env.application`，再通过
# `docker compose --env-file .env.application -f docker-compose.yml -f docker-compose.application.yml ...`
# 注入。这里的默认值仅用于本地学习与 E2E，生产环境必须由 Secret Manager、CI/CD Secret 或集群 Secret 提供。

DATASMART_IMAGE_TAG=local
DATASMART_RUNTIME_PROFILE=container

# 基础设施本地凭据。生产环境不得沿用示例值。
DATASMART_MYSQL_PASSWORD=password
DATASMART_NEO4J_PASSWORD=password
DATASMART_MINIO_ACCESS_KEY=datasmart
DATASMART_MINIO_SECRET_KEY=datasmart123
DATASMART_GRAFANA_ADMIN_PASSWORD=admin

# Gateway 与 Python Runtime 之间的 HMAC 密钥。至少使用 32 字节高熵随机值。
DATASMART_GATEWAY_SIGNATURE_SECRET=replace-with-a-long-random-secret
DATASMART_GATEWAY_SIGNATURE_KEY_ID=gateway-compose-v1

# Token 的 issuer 仍使用宿主机可访问地址；gateway 容器通过内部 JWK URL 获取公钥。
DATASMART_GATEWAY_OIDC_ISSUER_URI=http://localhost:18080/realms/datasmart
DATASMART_KEYCLOAK_ADMIN_USERNAME=admin
DATASMART_KEYCLOAK_ADMIN_PASSWORD=admin

# 可选真实模型服务。留空时 Python Runtime 仍可提供 dry-run、LangGraph 和低敏诊断能力。
DATASMART_AI_OPENAI_COMPATIBLE_BASE_URL=
DATASMART_AI_OPENAI_COMPATIBLE_API_KEY=

# 所有镜像默认通过 DaoCloud；若客户环境使用 Harbor/Nexus，可逐项覆盖为私有仓库地址。
DATASMART_MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.0
DATASMART_REDIS_IMAGE=docker.m.daocloud.io/library/redis:7.2-alpine
DATASMART_ZOOKEEPER_IMAGE=docker.m.daocloud.io/confluentinc/cp-zookeeper:7.6.0
DATASMART_KAFKA_IMAGE=docker.m.daocloud.io/confluentinc/cp-kafka:7.6.0
DATASMART_NEO4J_IMAGE=docker.m.daocloud.io/library/neo4j:5.20
DATASMART_MINIO_IMAGE=docker.m.daocloud.io/minio/minio:latest
DATASMART_NACOS_IMAGE=docker.m.daocloud.io/nacos/nacos-server:v2.3.0
DATASMART_KEYCLOAK_IMAGE=quay.m.daocloud.io/keycloak/keycloak:26.6.4
DATASMART_PROMETHEUS_IMAGE=docker.m.daocloud.io/prom/prometheus:latest
DATASMART_ALERTMANAGER_IMAGE=docker.m.daocloud.io/prom/alertmanager:latest
DATASMART_GRAFANA_IMAGE=docker.m.daocloud.io/grafana/grafana:latest
DATASMART_CHROMA_IMAGE=docker.m.daocloud.io/chromadb/chroma:latest
